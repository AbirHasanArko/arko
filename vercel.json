{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/github",
      "destination": "https://github.com/AbirHasanArko",
      "permanent": false
    },
    {
      "source": "/linkedin",
      "destination": "https://www.linkedin.com/in/abirhasanarko",
      "permanent": false
    }
  ]
}